{
  "name": "User Login",
  "description": "User authenticates via the web app; the API checks credentials in the database.",
  "components": [
    { "id": "user",   "name": "User",          "type": "user" },
    { "id": "webapp", "name": "Login Web App",  "type": "webapp" },
    { "id": "api",    "name": "Auth API",       "type": "api" },
    { "id": "db",     "name": "User Database",  "type": "database" }
  ],
  "data_flows": [
    { "id": "f1", "from": "user",   "to": "webapp", "label": "Enter credentials", "protocol": "HTTPS", "auth": "session", "encrypted": true },
    { "id": "f2", "from": "webapp", "to": "api",    "label": "POST /login",       "protocol": "HTTPS", "auth": "bearer",  "encrypted": true },
    { "id": "f3", "from": "api",    "to": "db",     "label": "Query user row",    "protocol": "TCP",   "auth": "credentials", "encrypted": false }
  ],
  "trust_boundaries": [
    { "id": "b_pub", "name": "Public / Internet",  "contains": ["user", "webapp"] },
    { "id": "b_int", "name": "Internal (private)", "contains": ["api", "db"] }
  ]
}
