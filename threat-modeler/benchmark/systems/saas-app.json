{
  "name": "Example SaaS App",
  "description": "SaaS web application with REST API and PostgreSQL",
  "components": [
    {
      "id": "c_user",
      "name": "User",
      "type": "user",
      "description": "End user via browser"
    },
    {
      "id": "c_web",
      "name": "Web App",
      "type": "webapp",
      "description": "React frontend"
    },
    {
      "id": "c_api",
      "name": "API Server",
      "type": "api",
      "description": "Node.js REST API"
    },
    {
      "id": "c_db",
      "name": "PostgreSQL",
      "type": "database",
      "description": "Primary database"
    },
    {
      "id": "c_cache",
      "name": "Redis",
      "type": "cache",
      "description": "Session cache"
    }
  ],
  "data_flows": [
    {
      "id": "f_1",
      "from": "c_user",
      "to": "c_web",
      "label": "HTTPS request",
      "protocol": "HTTPS",
      "auth": "none",
      "encrypted": true
    },
    {
      "id": "f_2",
      "from": "c_web",
      "to": "c_api",
      "label": "REST API call",
      "protocol": "HTTPS",
      "auth": "bearer",
      "encrypted": true
    },
    {
      "id": "f_3",
      "from": "c_api",
      "to": "c_db",
      "label": "SQL query",
      "protocol": "TCP",
      "auth": "credentials",
      "encrypted": false
    },
    {
      "id": "f_4",
      "from": "c_api",
      "to": "c_cache",
      "label": "Cache read/write",
      "protocol": "TCP",
      "auth": "none",
      "encrypted": false
    }
  ],
  "trust_boundaries": [
    {
      "id": "b_public",
      "name": "Public Internet",
      "contains": [
        "c_user",
        "c_web"
      ]
    },
    {
      "id": "b_app",
      "name": "Application Tier",
      "contains": [
        "c_api"
      ]
    },
    {
      "id": "b_data",
      "name": "Data Tier",
      "contains": [
        "c_db",
        "c_cache"
      ]
    }
  ]
}