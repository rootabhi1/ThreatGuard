# Copy to .env and fill in before running `docker compose up`.
#   cp .env.example .env

# --- Required ---
# Persistent JWT signing secret. If this changes, everyone is logged out.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# First-run admin account (created only if no admin exists yet).
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-now

# --- Optional ---
# Comma-separated allowed browser origins (default: *). Set this in production.
# CORS_ORIGINS=https://threatmodel.corp.internal

# Enable Claude LLM enhancement by setting your key
ANTHROPIC_API_KEY=

# --- LLM provider selection (optional) ---
# LLM_PROVIDER: "anthropic" (default) or "openai". If unset, auto-detected from
# whichever key is present. The "openai" backend also works with any
# OpenAI-compatible endpoint (Azure OpenAI, Ollama, vLLM, LiteLLM, OpenRouter,
# Together, Groq) via OPENAI_BASE_URL.
# LLM_PROVIDER=anthropic
#
# Anthropic:
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_VISION_MODEL=claude-opus-4-8
#
# OpenAI-compatible:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_BASE_URL=http://localhost:11434/v1   # e.g. Ollama
