      {"id":"c_svc_b","name":"Service B","type":"api","description":"Supporting domain service"},
      {"id":"c_bus","name":"Event Bus","type":"queue","description":"Kafka / RabbitMQ"},
      {"id":"c_db_a","name":"DB (Service A)","type":"database","description":"Postgres for Service A"},
      {"id":"c_db_b","name":"DB (Service B)","type":"database","description":"Postgres for Service B"},
      {"id":"c_secrets","name":"Secrets Store","type":"config","description":"HashiCorp Vault / AWS SSM"},
      {"id":"c_admin","name":"Admin Panel","type":"admin_panel","description":"Internal ops dashboard"}
