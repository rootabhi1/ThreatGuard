      {"id":"f_3","from":"c_ingress","to":"c_svc_a","label":"Routed request","protocol":"gRPC","auth":"mtls","encrypted":true},
      {"id":"f_4","from":"c_svc_a","to":"c_bus","label":"Domain events","protocol":"TCP","auth":"api_key","encrypted":false},
      {"id":"f_5","from":"c_bus","to":"c_svc_b","label":"Event stream","protocol":"TCP","auth":"api_key","encrypted":false},
      {"id":"f_6","from":"c_svc_a","to":"c_db_a","label":"Queries","protocol":"TCP","auth":"credentials","encrypted":false},
      {"id":"f_7","from":"c_svc_b","to":"c_db_b","label":"Queries","protocol":"TCP","auth":"credentials","encrypted":false},
      {"id":"f_8","from":"c_svc_a","to":"c_secrets","label":"Secret fetch","protocol":"HTTPS","auth":"mtls","encrypted":true},
      {"id":"f_9","from":"c_admin","to":"c_svc_a","label":"Admin ops","protocol":"HTTPS","auth":"session","encrypted":true}
    ],
    "trust_boundaries": [
      {"id":"b_public","name":"Public Internet","contains":["c_user"]},
      {"id":"b_edge","name":"Edge","contains":["c_ingress","c_auth"]},
      {"id":"b_services","name":"Service Mesh","contains":["c_svc_a","c_svc_b","c_bus"]},
      {"id":"b_data","name":"Data Tier","contains":["c_db_a","c_db_b"]},
      {"id":"b_mgmt","name":"Management","contains":["c_secrets","c_admin"]}
