[
  {
    "id": "saas-webapp",
    "name": "SaaS Web App",
    "description": "React/Vue frontend, REST API, PostgreSQL, Redis cache, Auth0",
    "icon": "🌐",
    "components": [
      {"id":"c_user","name":"User","type":"user","description":"End user via browser"},
      {"id":"c_cdn","name":"CDN / Frontend","type":"webapp","description":"React SPA served via CDN"},
      {"id":"c_api","name":"API Server","type":"api","description":"Node.js / Django REST API"},
      {"id":"c_auth","name":"Auth0","type":"auth_service","description":"External identity provider"},
      {"id":"c_db","name":"PostgreSQL","type":"database","description":"Primary relational database"},
      {"id":"c_cache","name":"Redis","type":"cache","description":"Session + hot-data cache"},
      {"id":"c_stripe","name":"Stripe","type":"payment_service","description":"Payment processor"}
    ],
    "data_flows": [
      {"id":"f_1","from":"c_user","to":"c_cdn","label":"HTTPS request","protocol":"HTTPS","auth":"none","encrypted":true},
      {"id":"f_2","from":"c_cdn","to":"c_auth","label":"OAuth2 login","protocol":"HTTPS","auth":"oauth2","encrypted":true},
      {"id":"f_3","from":"c_cdn","to":"c_api","label":"REST calls","protocol":"HTTPS","auth":"bearer","encrypted":true},
      {"id":"f_4","from":"c_api","to":"c_db","label":"SQL queries","protocol":"TCP","auth":"credentials","encrypted":false},
      {"id":"f_5","from":"c_api","to":"c_cache","label":"Cache read/write","protocol":"TCP","auth":"none","encrypted":false},
      {"id":"f_6","from":"c_api","to":"c_stripe","label":"Payment API","protocol":"HTTPS","auth":"api_key","encrypted":true}
    ],
    "trust_boundaries": [
      {"id":"b_internet","name":"Public Internet","contains":["c_user","c_cdn"]},
      {"id":"b_app","name":"Application Tier","contains":["c_api","c_auth"]},
      {"id":"b_data","name":"Data Tier","contains":["c_db","c_cache"]},
      {"id":"b_external","name":"External Services","contains":["c_stripe"]}
    ]
  },
  {
