# ─────────────────────────────────────────────────────────
#  ThreatGuard — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────

# Admin account created automatically on first run
INITIAL_ADMIN_EMAIL=admin@yourcompany.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Random secret for signing JWT tokens — generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace_with_a_long_random_string_at_least_48_chars

# ── LLM PROVIDER (OPTIONAL) ──────────────────────────────
# ThreatGuard works fully offline with its rule-based engine.
# Configuring a provider adds AI enrichment (fix generation, diagram
# extraction, richer narratives). Leave all blank for rules-only mode.
#
# Provider is auto-detected from whichever key is set; override with
# LLM_PROVIDER = anthropic | openai
LLM_PROVIDER=

# Option A — Anthropic (Claude). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_VISION_MODEL=claude-opus-4-8

# Option B — OpenAI-compatible endpoint. Works with OpenAI, Azure OpenAI,
# Ollama, vLLM, LM Studio, or any /v1/chat/completions-compatible server.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Point this at your endpoint for self-hosted / Azure (e.g. http://localhost:11434/v1)
OPENAI_BASE_URL=

# ── SERVER / SECURITY (OPTIONAL) ─────────────────────────

# Bind address (default: 127.0.0.1 for local, 0.0.0.0 for Docker)
HOST=127.0.0.1

# Port (default: 8000)
PORT=8000

# CORS allowed origins (comma-separated; default: * — restrict in production)
CORS_ORIGINS=*

# Per-IP login/refresh rate limiting (default: enabled). Set to 0 to disable.
RATE_LIMIT_ENABLED=1
