# ─────────────────────────────────────────────────────────
#  ThreatGuard — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────

# Admin account created automatically on first run
INITIAL_ADMIN_EMAIL=admin@yourcompany.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Random secret for signing JWT tokens — generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace_with_a_long_random_string_at_least_48_chars

# ── OPTIONAL ─────────────────────────────────────────────

# Claude AI enrichment — get key at https://console.anthropic.com
# Leave blank to use rule-based analysis only (still fully functional)
ANTHROPIC_API_KEY=

# Server bind address (default: 127.0.0.1 for local, 0.0.0.0 for Docker)
HOST=127.0.0.1

# Port (default: 8000)
PORT=8000

# CORS allowed origins (default: * — restrict in production)
CORS_ORIGINS=*
